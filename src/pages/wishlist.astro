---
import PageLayout from '@layouts/PageLayout.astro';
import EmptyState from '@components/EmptyState.astro';
import HighlightChips from '@components/HighlightChips.astro';
import { getWishlist } from '@lib/d1-client';
import { loadWishlist } from '@lib/ssg-data';
import type { WishlistItem } from '@lib/types';

const runtime = Astro.locals.runtime;
let items: WishlistItem[];

if (runtime?.env?.DB) {
  items = await getWishlist(runtime.env.DB);
} else {
  items = loadWishlist();
}
---

<PageLayout title="旅游心愿单" currentPage="wishlist">
  <section class="hero hero--compact">
    <div class="hero-content">
      <h1>旅游心愿单</h1>
      <p>世界那么大，我想去看看</p>
    </div>
  </section>

  <div class="container">
    {items.length > 0 ? (
      <div class="wishlist-grid">
        {items.map((item) => (
          <article class="wishlist-card">
            <div class="wishlist-emoji" aria-hidden="true">{item.emoji || '✈️'}</div>
            <div class="wishlist-body">
              <h2 class="wishlist-title">{item.title}</h2>
              <div class="wishlist-meta">
                <span>{item.city}</span>
                {item.season && <span>{item.season}</span>}
                {item.duration && <span>{item.duration}</span>}
              </div>
              {item.description && (
                <p class="wishlist-desc">{item.description}</p>
              )}
              {item.highlights.length > 0 && (
                <HighlightChips
                  highlights={item.highlights.map((h: any) => ({
                    id: h.id || 0,
                    journeyId: 0,
                    text: typeof h === 'string' ? h : h.text,
                    sortOrder: h.sortOrder || 0,
                  }))}
                  variant="yellow"
                />
              )}
            </div>
          </article>
        ))}
      </div>
    ) : (
      <EmptyState
        icon="heart"
        title="还没有心愿目的地"
        description="在管理后台添加想去的地方吧"
        actionText="添加心愿"
        actionHref="/admin/wishlist/new"
      />
    )}
  </div>
</PageLayout>

<style>
  .hero--compact {
    background: linear-gradient(135deg, var(--color-primary) 0%, #27272A 100%);
    color: var(--color-text-inverse);
    padding: var(--space-12) var(--space-4);
    text-align: center;
    margin-bottom: var(--space-8);
  }

  .hero-content {
    max-width: 640px;
    margin: 0 auto;
  }

  .hero--compact h1 {
    font-family: var(--font-heading);
    font-size: var(--fs-3xl);
    color: #fff;
    margin-bottom: var(--space-2);
  }

  .hero--compact p {
    font-size: var(--fs-lg);
    color: rgba(255,255,255,0.7);
  }

  .wishlist-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: var(--space-4);
    padding-bottom: var(--space-16);
  }

  @media (max-width: 480px) {
    .wishlist-grid {
      grid-template-columns: 1fr;
    }
  }

  .wishlist-card {
    display: flex;
    gap: var(--space-4);
    padding: var(--space-4);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 4px solid var(--color-warning);
    border-radius: var(--radius-md);
    transition: box-shadow var(--dur-fast) var(--ease-out);
    text-decoration: none;
    color: inherit;
  }
  .wishlist-card:hover {
    box-shadow: var(--shadow-card-hover);
  }

  .wishlist-emoji {
    font-size: 2.5rem;
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-surface-alt);
    border-radius: var(--radius-sm);
    flex-shrink: 0;
    line-height: 1;
  }

  .wishlist-body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .wishlist-title {
    font-family: var(--font-heading);
    font-size: var(--fs-xl);
    margin: 0;
    line-height: var(--lh-tight);
  }

  .wishlist-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
  }
  .wishlist-meta span + span::before {
    content: '·';
    margin-right: var(--space-2);
  }

  .wishlist-desc {
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
    line-height: var(--lh-relaxed);
    margin: 0;
  }

  .container {
    width: 100%;
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--space-4);
  }
</style>
