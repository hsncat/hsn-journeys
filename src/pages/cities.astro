---
import PageLayout from '@layouts/PageLayout.astro';
import EmptyState from '@components/EmptyState.astro';
import Icons from '@components/Icons.astro';
import { getJourneys } from '@lib/d1-client';
import { loadJourneys } from '@lib/ssg-data';
import { sumCosts } from '@lib/journey-helpers';
import type { Journey } from '@lib/types';

const runtime = Astro.locals.runtime;
let journeys: Journey[];

if (runtime?.env?.DB) {
  journeys = await getJourneys(runtime.env.DB);
} else {
  journeys = loadJourneys();
}
---

<PageLayout title="城市足迹" currentPage="cities">
  <div class="container">
    <h1 class="page-title">我的城市足迹</h1>

    <!-- Toolbar -->
    <div class="cities-toolbar">
      <div class="search-input">
        <span class="search-input__icon" aria-hidden="true">
          <Icons name="search" size={18} />
        </span>
        <input
          type="search"
          id="city-search"
          placeholder="搜索城市、景点或国家…"
          aria-label="搜索旅程"
          autocomplete="off"
        />
      </div>
      <div class="cities-filters" role="group" aria-label="筛选旅程">
        <button class="filter-chip is-active" type="button" data-filter="all" aria-pressed="true">全部</button>
        <button class="filter-chip" type="button" data-filter="domestic" aria-pressed="false">国内</button>
        <button class="filter-chip" type="button" data-filter="international" aria-pressed="false">国外</button>
      </div>
    </div>

    <div class="cities-layout">
      <!-- Timeline Sidebar -->
      <aside class="cities-timeline" aria-label="旅程时间线">
        <div class="cities-timeline__header">
          <span class="cities-timeline__eyebrow">Timeline</span>
          <h2>旅行时间线</h2>
        </div>
        {journeys.length > 0 ? (
          <ol class="cities-timeline__list">
            {journeys.map((j) => (
              <li class="timeline-item">
                <a href={`#journey-${j.id}`}>
                  <span class="timeline-dot" aria-hidden="true"></span>
                  <span class="timeline-emoji">{j.emoji}</span>
                  <span class="timeline-label">{j.title || j.city}</span>
                  <span class="timeline-date">{j.date}</span>
                </a>
              </li>
            ))}
          </ol>
        ) : (
          <p class="timeline-empty">暂无旅行记录</p>
        )}
      </aside>

      <!-- Main Grid -->
      <div class="city-grid">
        {journeys.length > 0 ? (
          journeys.map((j) => (
            <details class="city-card" id={`journey-${j.id}`}>
              <summary class="city-card__summary">
                <div class="city-card__header">
                  <span class="city-card__emoji" aria-hidden="true">{j.emoji}</span>
                  <div class="city-card__meta">
                    <h3 class="city-card__title">{j.title || j.city}</h3>
                    <span class="city-card__location">{j.country} · {j.city}</span>
                    <span class="city-card__cost">
                      总费用 ¥{(sumCosts(j.costs) / 10000).toFixed(1)}万
                      {j.subCards.length > 0 && ` · ${j.subCards.length} 个子行程`}
                    </span>
                  </div>
                </div>
                <span class="city-card__chevron" aria-hidden="true">
                  <Icons name="chevronDown" size={18} />
                </span>
              </summary>
              <div class="city-card__body">
                {j.description && <p class="city-card__desc">{j.description}</p>}
                {j.highlights.length > 0 && (
                  <div class="city-card__highlights">
                    {j.highlights.slice(0, 6).map((h) => (
                      <span class="chip">{h.text}</span>
                    ))}
                  </div>
                )}
                <a class="btn btn-primary btn-sm" href={`/cities/${j.id}`}>
                  查看详情 &rarr;
                </a>
              </div>
            </details>
          ))
        ) : (
          <EmptyState
            icon="mapPin"
            title="还没有旅行记录"
            description="开始记录你的旅行足迹吧"
            actionText="添加旅程"
            actionHref="/admin/journeys/new"
          />
        )}
      </div>
    </div>
  </div>
</PageLayout>

<style>
  .page-title {
    font-family: var(--font-heading);
    font-size: var(--fs-3xl);
    margin: var(--space-6) 0;
    text-align: center;
  }

  /* Toolbar */
  .cities-toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
    align-items: center;
    justify-content: center;
  }

  .search-input {
    position: relative;
    flex: 1;
    max-width: 360px;
    min-width: 200px;
  }

  .search-input__icon {
    position: absolute;
    left: var(--space-3);
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-text-faint);
    pointer-events: none;
    display: flex;
  }

  .search-input input {
    width: 100%;
    padding: var(--space-2) var(--space-3) var(--space-2) calc(var(--space-3) + 24px);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-size: var(--fs-sm);
    font-family: inherit;
    background: var(--color-surface);
    color: var(--color-text);
    transition: border-color var(--dur-fast) var(--ease-out);
  }
  .search-input input:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: var(--shadow-focus);
  }

  .cities-filters {
    display: flex;
    gap: var(--space-2);
  }

  .filter-chip {
    padding: var(--space-1) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    background: var(--color-surface);
    font-size: var(--fs-sm);
    font-family: inherit;
    cursor: pointer;
    color: var(--color-text-muted);
    transition: all var(--dur-fast) var(--ease-out);
  }
  .filter-chip.is-active,
  .filter-chip:hover {
    background: var(--color-accent);
    color: #fff;
    border-color: var(--color-accent);
  }

  /* Layout */
  .cities-layout {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: var(--space-8);
    align-items: start;
  }

  @media (max-width: 768px) {
    .cities-layout {
      grid-template-columns: 1fr;
    }
  }

  /* Timeline */
  .cities-timeline {
    position: sticky;
    top: calc(var(--navbar-height) + var(--space-6));
    max-height: calc(100vh - var(--navbar-height) - var(--space-12));
    overflow-y: auto;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-4);
  }

  @media (max-width: 768px) {
    .cities-timeline {
      position: static;
      max-height: none;
    }
  }

  .cities-timeline__header {
    margin-bottom: var(--space-4);
  }

  .cities-timeline__eyebrow {
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-faint);
    font-weight: var(--fw-semibold);
  }

  .cities-timeline__header h2 {
    font-size: var(--fs-lg);
    margin-top: 0;
  }

  .cities-timeline__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    border-left: 2px solid var(--color-border);
    padding-left: var(--space-4);
  }

  .timeline-item a {
    display: grid;
    grid-template-columns: auto auto 1fr auto;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) 0;
    text-decoration: none;
    color: inherit;
    font-size: var(--fs-sm);
    position: relative;
    transition: color var(--dur-fast) var(--ease-out);
  }

  .timeline-item a:hover {
    color: var(--color-accent);
  }

  .timeline-dot {
    position: absolute;
    left: calc(-1 * var(--space-4) - 5px);
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-border-strong);
    top: 50%;
    transform: translateY(-50%);
  }

  .timeline-emoji {
    font-size: 1rem;
    width: 24px;
    text-align: center;
  }

  .timeline-label {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .timeline-date {
    color: var(--color-text-faint);
    font-size: var(--fs-xs);
    white-space: nowrap;
  }

  .timeline-empty {
    padding: var(--space-4);
    color: var(--color-text-muted);
    font-size: var(--fs-sm);
    text-align: center;
  }

  /* City cards */
  .city-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .city-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: box-shadow var(--dur-fast) var(--ease-out);
  }
  .city-card[open] {
    box-shadow: var(--shadow-md);
  }

  .city-card__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-4);
    cursor: pointer;
    user-select: none;
    list-style: none;
    gap: var(--space-3);
  }
  .city-card__summary::-webkit-details-marker { display: none; }

  .city-card__header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex: 1;
    min-width: 0;
  }

  .city-card__emoji {
    font-size: 2rem;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-surface-alt);
    border-radius: var(--radius-sm);
    flex-shrink: 0;
  }

  .city-card__meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .city-card__title {
    font-family: var(--font-heading);
    font-size: var(--fs-lg);
    margin: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .city-card__location {
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
  }

  .city-card__cost {
    font-size: var(--fs-xs);
    color: var(--color-text-faint);
  }

  .city-card__chevron {
    color: var(--color-text-muted);
    transition: transform var(--dur-fast) var(--ease-out);
    flex-shrink: 0;
  }

  .city-card[open] .city-card__chevron {
    transform: rotate(180deg);
  }

  .city-card__body {
    padding: 0 var(--space-4) var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .city-card__desc {
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
    line-height: var(--lh-relaxed);
    margin: 0;
  }

  .city-card__highlights {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .chip {
    display: inline-block;
    padding: 2px var(--space-3);
    border-radius: var(--radius-pill);
    font-size: var(--fs-xs);
    font-weight: var(--fw-medium);
    background: var(--color-accent-soft);
    color: var(--color-accent);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-6);
    border-radius: var(--radius-sm);
    font-size: var(--fs-sm);
    font-weight: var(--fw-semibold);
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: all var(--dur-fast) var(--ease-out);
  }
  .btn-primary {
    background: var(--color-accent);
    color: #fff;
  }
  .btn-primary:hover {
    background: var(--color-accent-hover);
    color: #fff;
  }
  .btn-sm {
    align-self: flex-start;
    margin-top: var(--space-2);
  }
</style>

<script>
  // Client-side search and filter
  const searchInput = document.getElementById('city-search') as HTMLInputElement | null;
  const filterChips = document.querySelectorAll<HTMLButtonElement>('.filter-chip');

  function filterCards() {
    const query = searchInput?.value?.toLowerCase() || '';
    const activeFilter = document.querySelector('.filter-chip.is-active')?.getAttribute('data-filter') || 'all';

    document.querySelectorAll<HTMLElement>('.city-card').forEach((card) => {
      const text = (card.textContent || '').toLowerCase();
      const country = card.querySelector('.city-card__location')?.textContent?.toLowerCase() || '';

      const matchesSearch = !query || text.includes(query);
      const matchesFilter = activeFilter === 'all'
        || (activeFilter === 'domestic' && country.includes('中国'))
        || (activeFilter === 'international' && !country.includes('中国'));

      card.style.display = matchesSearch && matchesFilter ? '' : 'none';
    });

    // Also filter timeline items
    document.querySelectorAll<HTMLElement>('.timeline-item').forEach((item) => {
      const text = (item.textContent || '').toLowerCase();
      const isChina = text.includes('中国');
      const matchesSearch = !query || text.includes(query);
      const matchesFilter = activeFilter === 'all'
        || (activeFilter === 'domestic' && isChina)
        || (activeFilter === 'international' && !isChina);

      item.style.display = matchesSearch && matchesFilter ? '' : 'none';
    });
  }

  searchInput?.addEventListener('input', filterCards);

  filterChips.forEach((chip) => {
    chip.addEventListener('click', () => {
      filterChips.forEach((c) => {
        c.classList.remove('is-active');
        c.setAttribute('aria-pressed', 'false');
      });
      chip.classList.add('is-active');
      chip.setAttribute('aria-pressed', 'true');
      filterCards();
    });
  });
</script>
