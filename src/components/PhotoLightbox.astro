---
import { R2_PUBLIC_URL } from '@lib/constants';
import Icons from './Icons.astro';

export interface Props {
  src: string;
  alt?: string;
  photoKey?: string | null;
}

const { src, alt = '', photoKey } = Astro.props;
const imgSrc = photoKey
  ? `${R2_PUBLIC_URL}/${photoKey}`
  : src.startsWith('data:') ? src : `${R2_PUBLIC_URL}/${src}`;
---

<div class="photo-lightbox" id={`lightbox-${photoKey || 'main'}`}>
  <button
    class="photo-trigger"
    type="button"
    onclick={`document.querySelector('#lightbox-overlay-${photoKey || 'main'}')?.classList.add('is-open')`}
    aria-label="查看大图"
  >
    <img src={imgSrc} alt={alt} loading="lazy" />
    <span class="photo-zoom-icon" aria-hidden="true">
      <Icons name="search" size={20} />
    </span>
  </button>

  <div
    class="lightbox-overlay"
    id={`lightbox-overlay-${photoKey || 'main'}`}
    role="dialog"
    aria-modal="true"
    aria-label="图片预览"
  >
    <div class="lightbox-backdrop" onclick={`this.parentElement.classList.remove('is-open')`}></div>
    <button
      class="lightbox-close"
      type="button"
      onclick={`this.closest('.lightbox-overlay').classList.remove('is-open')`}
      aria-label="关闭"
    >
      <Icons name="x" size={24} />
    </button>
    <img src={imgSrc} alt={alt} class="lightbox-img" />
  </div>
</div>

<style>
  .photo-trigger {
    position: relative;
    display: block;
    border: none;
    background: none;
    padding: 0;
    cursor: pointer;
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .photo-trigger img {
    width: 100%;
    max-height: 480px;
    object-fit: cover;
    transition: transform var(--dur-slow) var(--ease-out);
  }

  .photo-trigger:hover img {
    transform: scale(1.02);
  }

  .photo-zoom-icon {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(0,0,0,0.55);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity var(--dur-fast) var(--ease-out);
  }
  .photo-trigger:hover .photo-zoom-icon {
    opacity: 1;
  }

  .lightbox-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: var(--z-modal);
  }

  .lightbox-overlay.is-open {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.85);
  }

  .lightbox-close {
    position: absolute;
    top: var(--space-4);
    right: var(--space-4);
    z-index: 1;
    background: none;
    border: none;
    color: #fff;
    cursor: pointer;
    padding: var(--space-2);
    border-radius: var(--radius-sm);
    transition: background var(--dur-fast) var(--ease-out);
  }
  .lightbox-close:hover {
    background: rgba(255,255,255,0.15);
  }

  .lightbox-img {
    position: relative;
    z-index: 1;
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: var(--radius-sm);
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
  }

  @keyframes lightboxIn {
    from { opacity: 0; transform: scale(0.95); }
    to { opacity: 1; transform: scale(1); }
  }

  .lightbox-overlay.is-open .lightbox-img {
    animation: lightboxIn var(--dur-slow) var(--ease-out);
  }
</style>

<script>
  // ESC key and focus trap for lightbox
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      document.querySelectorAll('.lightbox-overlay.is-open').forEach((el) => {
        el.classList.remove('is-open');
      });
    }
  });
</script>
