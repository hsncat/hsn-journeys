---
import type { ItineraryItem } from '@lib/types';

export interface Props {
  itinerary: ItineraryItem[];
}

const { itinerary } = Astro.props;

if (!itinerary || itinerary.length === 0) return null;

const headers = ['日期', '上午', '下午', '晚上', '备注'];
const fields: (keyof ItineraryItem)[] = ['date', 'morning', 'afternoon', 'evening', 'note'];
---

<div class="itinerary">
  <h3 class="itinerary-heading">行程表</h3>
  <div class="itinerary-table-wrap">
    <table class="itinerary-table">
      <thead>
        <tr>
          {headers.map(h => <th>{h}</th>)}
        </tr>
      </thead>
      <tbody>
        {itinerary.map((row) => (
          <tr>
            {fields.map(f => <td>{row[f]}</td>)}
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <div class="itinerary-cards">
    {itinerary.map((row) => (
      <div class="itinerary-card">
        <div class="itinerary-card__date">{row.date}</div>
        <div class="itinerary-card__row">
          <span class="itinerary-card__label">上午</span>
          <span>{row.morning}</span>
        </div>
        <div class="itinerary-card__row">
          <span class="itinerary-card__label">下午</span>
          <span>{row.afternoon}</span>
        </div>
        <div class="itinerary-card__row">
          <span class="itinerary-card__label">晚上</span>
          <span>{row.evening}</span>
        </div>
        {row.note && (
          <div class="itinerary-card__row">
            <span class="itinerary-card__label">备注</span>
            <span>{row.note}</span>
          </div>
        )}
      </div>
    ))}
  </div>
</div>

<style>
  .itinerary {
    margin: var(--space-6) 0;
  }

  .itinerary-heading {
    font-family: var(--font-heading);
    font-size: var(--fs-xl);
    margin-bottom: var(--space-4);
  }

  .itinerary-table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .itinerary-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--fs-sm);
    display: none;
  }

  .itinerary-table th,
  .itinerary-table td {
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--color-border);
    text-align: left;
    vertical-align: top;
  }

  .itinerary-table th {
    background: var(--color-surface-alt);
    font-weight: var(--fw-semibold);
    white-space: nowrap;
    color: var(--color-text-muted);
  }

  .itinerary-table td {
    min-width: 80px;
  }

  @media (min-width: 768px) {
    .itinerary-table { display: table; }
    .itinerary-cards { display: none; }
  }

  .itinerary-cards {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  @media (min-width: 768px) {
    .itinerary-cards { display: none; }
  }

  .itinerary-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--space-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .itinerary-card__date {
    font-weight: var(--fw-semibold);
    font-size: var(--fs-sm);
    color: var(--color-accent);
    margin-bottom: var(--space-1);
  }

  .itinerary-card__row {
    display: flex;
    gap: var(--space-2);
    font-size: var(--fs-sm);
  }

  .itinerary-card__label {
    color: var(--color-text-muted);
    font-weight: var(--fw-medium);
    min-width: 40px;
    flex-shrink: 0;
  }
</style>
