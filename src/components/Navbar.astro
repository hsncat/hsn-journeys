---
import { icon } from '@/lib/icons';

interface Props {
  active?: 'home' | 'cities' | 'map' | 'wishlist';
}

const { active } = Astro.props;

const items: { key: NonNullable<Props['active']>; href: string; label: string }[] = [
  { key: 'home', href: '/', label: '首页' },
  { key: 'cities', href: '/cities', label: '城市足迹' },
  { key: 'map', href: '/map', label: '足迹地图' },
  { key: 'wishlist', href: '/wishlist', label: '心愿单' },
];
---

<header class="site-navbar">
  <div class="nav-inner">
    <a href="/" class="nav-brand">HSN Journey Traces</a>
    <input type="checkbox" id="nav-toggle" class="nav-toggle peer" />
    <label for="nav-toggle" class="nav-toggle-label" aria-label="菜单">
      <Fragment set:html={icon('menu', { size: 22 })} />
    </label>
    <nav class="nav-links">
      <ul>
        {items.map(item => (
          <li>
            <a
              href={item.href}
              class:list={['nav-link', active === item.key && 'is-active']}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: saturate(180%) blur(16px);
    -webkit-backdrop-filter: saturate(180%) blur(16px);
    background: rgba(24, 24, 27, 0.92);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 14px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }
  .nav-brand {
    font-family: var(--font-display);
    font-size: 28px;
    color: var(--color-text-inverse);
    letter-spacing: 0.5px;
    text-decoration: none;
  }
  .nav-toggle { display: none; }
  .nav-toggle-label {
    display: none;
    color: var(--color-text-inverse);
    padding: 6px;
    border-radius: 6px;
  }
  .nav-links ul {
    list-style: none;
    margin: 0; padding: 0;
    display: flex;
    gap: 4px;
  }
  .nav-link {
    display: inline-flex;
    align-items: center;
    height: 36px;
    padding: 0 14px;
    border-radius: 999px;
    text-decoration: none;
    color: rgba(250, 250, 250, 0.72);
    font-weight: 500;
    font-size: 14px;
    transition: all 200ms var(--ease-out);
  }
  .nav-link:hover {
    color: var(--color-text-inverse);
    background: rgba(255, 255, 255, 0.08);
  }
  .nav-link.is-active {
    color: var(--color-primary);
    background: var(--color-text-inverse);
  }

  @media (max-width: 768px) {
    .nav-toggle-label { display: inline-flex; cursor: pointer; }
    .nav-links {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: rgba(24, 24, 27, 0.98);
      backdrop-filter: blur(12px);
      transform-origin: top;
      transform: scaleY(0);
      transition: transform 200ms var(--ease-out);
    }
    .nav-toggle:checked ~ .nav-links {
      transform: scaleY(1);
    }
    .nav-links ul {
      flex-direction: column;
      padding: 12px;
      gap: 4px;
    }
    .nav-link {
      width: 100%;
      height: 44px;
      border-radius: 12px;
    }
  }
</style>
